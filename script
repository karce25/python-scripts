#!/bin/bash

# Script to list Wide-IPs with "Availability : available" using grep

# Output file path
OUTPUT_FILE="/path/to/your/output/wide_ips_available.txt"

# Check if running as root, since tmsh requires elevated privileges
if [[ $EUID -ne 0 ]]; then
    echo "This script must be run as root."
    exit 1
fi

echo "Retrieving all wide-IPs that are AVAILABLE..."

# Use grep to capture wide-IP names followed by "Availability : available"
tmsh -q show gtm wideip | grep -E 'Gtm::WideIp::|Availability : available' | grep -B 1 "Availability : available" | grep 'Gtm::WideIp::' | awk '{print $3}' > "$OUTPUT_FILE"

# Check if the output file contains any results
if [[ -s $OUTPUT_FILE ]]; then
    echo "Wide-IPs that are AVAILABLE have been written to $OUTPUT_FILE"
else
    echo "No wide-IPs are currently AVAILABLE."
    echo "No wide-IPs are currently AVAILABLE." > "$OUTPUT_FILE"
fi

exit 0
