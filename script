import csv

def check_column_matches(file_path, column1, column2):
    """
    Check if two columns in a CSV file match row by row.

    :param file_path: Path to the CSV file
    :param column1: Header or index of the first column
    :param column2: Header or index of the second column
    """
    try:
        with open(file_path, mode='r') as csv_file:
            reader = csv.DictReader(csv_file)  # Read as dictionary for column headers
            mismatches = []

            for index, row in enumerate(reader):
                value1 = row[column1]
                value2 = row[column2]

                if value1 != value2:
                    mismatches.append((index + 1, value1, value2))

            if mismatches:
                print(f"Found {len(mismatches)} mismatches:")
                for mismatch in mismatches:
                    print(f"Row {mismatch[0]}: {column1}='{mismatch[1]}' != {column2}='{mismatch[2]}'")
            else:
                print(f"All rows match for columns: {column1} and {column2}")

    except FileNotFoundError:
        print("Error: File not found.")
    except KeyError as e:
        print(f"Error: Column '{e}' not found in the CSV file.")
    except Exception as e:
        print(f"Error: {e}")

# Example Usage:
# Provide the file path and column names you want to compare.
file_path = 'example.csv'
column1 = 'ColumnA'
column2 = 'ColumnB'

check_column_matches(file_path, column1, column2)
