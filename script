#!/bin/bash

# Script to list all wide-IPs that are ONLINE in an F5 GTM device using tmsh

# Output file path
OUTPUT_FILE="/path/to/your/output/wide_ips_online.txt"

# Check if running as the root user
if [[ $EUID -ne 0 ]]; then
    echo "This script must be run as root."
    exit 1
fi

echo "Retrieving all wide-IPs that are ONLINE..."

# Temporary variable to store the current wide-IP name
current_wideip=""

# Execute tmsh and parse the output
tmsh -q show gtm wideip | while read -r line; do
    # Check for wide-IP name
    if [[ $line == Gtm::WideIp::* ]]; then
        current_wideip=$(echo "$line" | awk '{print $3}')
    fi

    # Check for availability status being online
    if [[ $line == *"Availability : online"* ]]; then
        echo "$current_wideip" >> "$OUTPUT_FILE"
    fi
done

# Check if we found any online wide-IPs
if [[ -s $OUTPUT_FILE ]]; then
    echo "Wide-IPs that are ONLINE have been written to $OUTPUT_FILE"
else
    echo "No wide-IPs are currently ONLINE."
    echo "No wide-IPs are currently ONLINE." > "$OUTPUT_FILE"
fi

exit 0
