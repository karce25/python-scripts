#!/bin/bash


INTERVAL=${1:-60}            
DURATION=${2:-60}            
OUTPUT_FILE="/var/tmp/vs_connections_$(date +%Y%m%d_%H%M%S).txt"


END_TIME=$(( $(date +%s) + (DURATION * 60) ))


echo "============================================================" >> "$OUTPUT_FILE"
echo " Start Time : $(date)" >> "$OUTPUT_FILE"
echo " Interval : ${INTERVAL}s" >> "$OUTPUT_FILE"
echo " Duration : ${DURATION} min" >> "$OUTPUT_FILE"
echo " Output File : ${OUTPUT_FILE}" >> "$OUTPUT_FILE"
echo "============================================================" >> "$OUTPUT_FILE"
echo "" >> "$OUTPUT_FILE"

echo "Output file: ${OUTPUT_FILE}"


echo "[INFO] Gathering list of Virtual Servers..." >> "$OUTPUT_FILE"

VS_LIST=$(tmsh list /ltm virtual destination 2>/dev/null | \
    awk '
    /^ltm virtual/ {
        vs_name = $3
    }
    /destination/ {
        dest = $2
        gsub(/%[0-9]+/, "", dest)
        n = split(dest, arr, ":")
        if (n == 2) {
            printf "%s|%s|%s\n", vs_name, arr[1], arr[2]
        }
    }')

if [ -z "$VS_LIST" ]; then
    echo "[ERROR] No Virtual Servers found or tmsh command failed."
    echo "[ERROR] No Virtual Servers found or tmsh command failed." >> "$OUTPUT_FILE"
    exit 1
fi

VS_COUNT=$(echo "$VS_LIST" | wc -l)
echo "[INFO] Found ${VS_COUNT} Virtual Server(s):" >> "$OUTPUT_FILE"
echo "$VS_LIST" | while IFS='|' read -r vs_name vs_ip vs_port; do
    echo "       - ${vs_name} -> ${vs_ip}:${vs_port}" >> "$OUTPUT_FILE"
done
echo "" >> "$OUTPUT_FILE"

#While loop
ITERATION=0
while [ "$(date +%s)" -lt "$END_TIME" ]; do
    ITERATION=$((ITERATION + 1))
    TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

    echo "Gathering information - Iteration #${ITERATION} (${TIMESTAMP})"

    echo "------------------------------------------------------------" >> "$OUTPUT_FILE"
    echo "[Iteration #${ITERATION}] Timestamp: ${TIMESTAMP}" >> "$OUTPUT_FILE"
    echo "------------------------------------------------------------" >> "$OUTPUT_FILE"

    echo "$VS_LIST" | while IFS='|' read -r vs_name vs_ip vs_port; do

        echo "" >> "$OUTPUT_FILE"
        echo ">>> VS: ${vs_name} (${vs_ip}:${vs_port})" >> "$OUTPUT_FILE"

        CONN_OUTPUT=$(tmsh show /sys connection cs-server-addr "${vs_ip}" cs-server-port "${vs_port}" 2>&1)

        # Count only actual connection lines (lines starting with an IP/number)
        CONN_COUNT=$(echo "$CONN_OUTPUT" | grep -cE '^[0-9]')

        if [ "$CONN_COUNT" -eq 0 ]; then
            echo "    [No active connections]" >> "$OUTPUT_FILE"
        else
            echo "    Active Connections: ${CONN_COUNT}" >> "$OUTPUT_FILE"
            echo "$CONN_OUTPUT" >> "$OUTPUT_FILE"
        fi

    done

    echo "" >> "$OUTPUT_FILE"
    echo "[Iteration #${ITERATION}] Complete." >> "$OUTPUT_FILE"
    echo "" >> "$OUTPUT_FILE"


    REMAINING=$(( END_TIME - $(date +%s) ))
    if [ "$REMAINING" -le 0 ]; then
        break
    fi

    if [ "$REMAINING" -lt "$INTERVAL" ]; then
        sleep "$REMAINING"
    else
        sleep "$INTERVAL"
    fi
done


echo "Done. ${ITERATION} iterations completed. Output saved to: ${OUTPUT_FILE}"

tmsh list ltm virtual one-line | grep "rules {.*xff-removal.*rhe-insert.*}" | awk '{print $3}'
